{
  "name": "mini-crm-tickets",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,cjs,mjs,cts,mts,json,yml,yaml,html}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,cjs,mjs,cts,mts,json,yml,yaml,html}\"",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.26.0"
  }
}
